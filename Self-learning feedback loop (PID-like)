# ====================== 3. 3D Visualization ======================
print("\n🌀 3D Visualization 생성...")
t_eval, u_sol, _ = run_simulation(I_opt=25e3, freq_mod=res_freq, t_max=25)
X, T = np.meshgrid(x, t_eval)
U = u_sol.T

fig = plt.figure(figsize=(12, 8))
