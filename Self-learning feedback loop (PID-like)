# ====================== 4. Self-learning PID-like Feedback Loop ======================
print("\n🧠 Self-learning PID Feedback Loop 시뮬레이션...")

# 목표 displacement (예: 2.0 nm)
target_u = 2.0
Kp, Ki, Kd = 0.8, 0.15, 0.05   # PID 게인 (튜닝 가능)
integral = 0
prev_error = 0
I_history = []
u_tip_history = []

t_max = 50
t_eval = np.linspace(0, t_max, 1000)
dt = t_eval[1] - t_eval[0]

u_tip = np.zeros_like(t_eval)
I_opt_control = np.ones_like(t_eval) * 15e3   # 초기 intensity

for i in range(1, len(t_eval)):
    # 현재 tip displacement (모델 근사)
    current_u = u_tip[i-1]
    error = target_u - current_u
    
    integral += error * dt
    derivative = (error - prev_error) / dt
    prev_error = error
    
    # PID 제어 (intensity 조절)
    control = Kp * error + Ki * integral + Kd * derivative
    I_opt_control[i] = np.clip(15e3 + control * 8000, 5e3, 60e3)
    
    # Dynamics 근사 (PID 적용 후)
    u_tip[i] = current_u + (I_opt_control[i]/25000 * 0.12 - 0.08 * current_u) * dt * 8

u_tip_history = u_tip

plt.figure(figsize=(11,7))
plt.subplot(2,1,1)
plt.plot(t_eval, u_tip, 'b-', label='Finger Tip Displacement')
plt.axhline(target_u, color='red', linestyle='--', label='Target (2.0 nm)')
plt.ylabel('Displacement (nm)')
plt.title('Self-learning PID Feedback Control')
plt.legend()
plt.grid(True)

plt.subplot(2,1,2)
plt.plot(t_eval, I_opt_control/1000, 'g-', label='Controlled Optical Intensity')
plt.xlabel('Time (ns)')
plt.ylabel('Intensity (kW/cm²)')
plt.legend()
plt.grid(True)
plt.tight_layout()
plt.show()

print(f"PID 제어 완료 - 최종 steady-state u ≈ {u_tip[-1]:.3f} nm (Target: {target_u} nm)")
