# 1. Resonance Animation + Heisenberg Noise + Real-time k_DNA
t, u_tip, k_DNA_t, noise = run_resonance_animation()

# 2. PID Auto-tuning
optimal_gains = pid_with_gd_tuning(target_u=2.5, epochs=20)

